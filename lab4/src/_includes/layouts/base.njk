<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="author" content="{{ site.author }}" />
    <title>{{ title or site.title }}</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <link rel="stylesheet" href="/assets/reset.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              coffee: {
                bg: '#FDF6EC',
                'bg-alt': '#FFFAF3',
                dark: '#3C2415',
                accent: '{{ site.theme.accent }}',
                'accent-hover': '{{ site.theme.accent_hover }}',
                secondary: '#E8D5B7',
                text: '#5C4033',
                'text-light': '#8B7355',
              }
            },
            fontFamily: {
              heading: ['Playfair Display', 'Georgia', 'serif'],
              body: ['Lato', 'Helvetica Neue', 'Arial', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      html { scroll-behavior: smooth; }
      body { font-family: 'Lato', 'Helvetica Neue', Arial, sans-serif; }

      /* Mascot tooltip */
      .mascot-tooltip {
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
      }
      .mascot-wrapper:hover .mascot-tooltip {
        opacity: 1;
        transform: translateY(0);
      }

      /* Burger menu — pure CSS checkbox hack */
      .burger-checkbox { display: none; }
      .mobile-menu { display: none; }
      .burger-checkbox:checked + header .mobile-menu { display: block; }
      .burger-checkbox:checked + header .burger-label .burger-line:nth-child(1) {
        transform: rotate(45deg) translate(4px, 4px);
      }
      .burger-checkbox:checked + header .burger-label .burger-line:nth-child(2) {
        opacity: 0;
      }
      .burger-checkbox:checked + header .burger-label .burger-line:nth-child(3) {
        transform: rotate(-45deg) translate(4px, -4px);
      }

      /* Mascot */
      .mascot-wrapper {
        opacity: 0;
        animation: slide-in 0.6s ease-out 3s forwards;
      }
      @keyframes slide-in {
        0% { transform: translateX(120px); opacity: 0; }
        100% { transform: translateX(0); opacity: 1; }
      }
      @keyframes bounce-gentle {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
      }
      @keyframes steam {
        0% { transform: translateY(0) scaleX(1); opacity: 0.6; }
        50% { transform: translateY(-8px) scaleX(1.2); opacity: 0.3; }
        100% { transform: translateY(-16px) scaleX(0.8); opacity: 0; }
      }
      .animate-bounce-gentle { animation: bounce-gentle 2s ease-in-out infinite; }
      .animate-steam { animation: steam 2s ease-in-out infinite; }

      /* Gallery hover zoom */
      .gallery-img { transition: transform 0.3s ease; }
      .gallery-item:hover .gallery-img { transform: scale(1.05); }

      /* Nav link underline */
      .nav-link { position: relative; }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background-color: {{ site.theme.accent }};
        transition: width 0.3s ease;
      }
      .nav-link:hover::after { width: 100%; }
    </style>
  </head>

  <body class="bg-coffee-bg text-coffee-text leading-relaxed text-base">

    <!-- Burger checkbox -->
    <input type="checkbox" id="burger-toggle" class="burger-checkbox" />
    <header class="sticky top-0 z-50 bg-coffee-bg border-b border-coffee-secondary">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between py-4">
        <a href="/" class="flex items-center">
          <img src="{{ site.logo }}" alt="{{ site.title }} logo" class="h-12 w-auto rounded-full" />
        </a>
        <nav class="hidden md:block">
          <ul class="flex gap-8">
            {% for link in site.nav_links %}
            <li><a href="{{ link.href }}" class="nav-link text-sm text-coffee-text hover:text-coffee-accent transition-colors">{{ link.label }}</a></li>
            {% endfor %}
          </ul>
        </nav>
        <label for="burger-toggle" class="burger-label md:hidden flex flex-col gap-1.5 p-1 cursor-pointer" aria-label="Toggle menu">
          <span class="burger-line block w-6 h-0.5 bg-coffee-dark transition-all duration-300"></span>
          <span class="burger-line block w-6 h-0.5 bg-coffee-dark transition-all duration-300"></span>
          <span class="burger-line block w-6 h-0.5 bg-coffee-dark transition-all duration-300"></span>
        </label>
      </div>
      <div class="mobile-menu md:hidden bg-coffee-bg border-b border-coffee-secondary px-6 pb-6">
        <ul class="flex flex-col gap-4 items-center">
          {% for link in site.nav_links %}
          <li><a href="{{ link.href }}" class="text-coffee-text hover:text-coffee-accent transition-colors">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-coffee-dark py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
        <p class="text-coffee-secondary text-sm">&copy; {{ site.year }} Coffee Varka. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="{{ site.social.instagram }}" target="_blank" class="text-coffee-secondary text-sm hover:text-coffee-accent transition-colors">Instagram</a>
          <a href="{{ site.social.facebook }}" target="_blank" class="text-coffee-secondary text-sm hover:text-coffee-accent transition-colors">Facebook</a>
          <a href="{{ site.social.tiktok }}" target="_blank" class="text-coffee-secondary text-sm hover:text-coffee-accent transition-colors">TikTok</a>
        </div>
      </div>
    </footer>

    {% if site.mobile_cta.sticky_bar.enabled %}
    <!-- Mobile-only: Sticky CTA Bar -->
    <div class="fixed bottom-0 left-0 right-0 z-40 bg-coffee-dark/95 backdrop-blur-sm py-3 px-4 flex items-center justify-between md:hidden">
      <span class="text-white text-sm font-bold">{{ site.mobile_cta.sticky_bar.text }}</span>
      <a href="{{ site.mobile_cta.sticky_bar.button_link }}" class="px-5 py-2 rounded-lg font-bold text-sm text-white bg-coffee-accent hover:bg-coffee-accent-hover transition-colors">{{ site.mobile_cta.sticky_bar.button_label }}</a>
    </div>
    {% endif %}

    {% if site.mascot.enabled %}
    <!-- Coffee Cup Mascot -->
    <div class="mascot-wrapper fixed bottom-20 right-4 md:bottom-8 md:right-8 z-50 cursor-pointer">
      <div class="relative">
        <div class="mascot-tooltip absolute bottom-full right-0 mb-3 bg-white rounded-xl shadow-lg px-4 py-3 w-52 text-center border border-coffee-secondary">
          <p class="text-sm text-coffee-dark font-bold mb-1">{{ site.mascot.title }}</p>
          <p class="text-xs text-coffee-text-light">{{ site.mascot.message }}</p>
          <div class="absolute -bottom-2 right-6 w-4 h-4 bg-white border-b border-r border-coffee-secondary rotate-45"></div>
        </div>
        <svg class="animate-bounce-gentle" width="80" height="100" viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path class="animate-steam" d="M28 28 Q30 20 28 12" stroke="#C07A45" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.5" />
          <path class="animate-steam" style="animation-delay: 0.4s" d="M38 26 Q40 18 38 10" stroke="#C07A45" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.5" />
          <path class="animate-steam" style="animation-delay: 0.8s" d="M48 28 Q50 20 48 12" stroke="#C07A45" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.5" />
          <rect x="14" y="32" width="48" height="50" rx="8" fill="#C07A45" />
          <rect x="18" y="36" width="40" height="20" rx="4" fill="#5C4033" />
          <path d="M62 46 Q74 46 74 58 Q74 70 62 70" stroke="#C07A45" stroke-width="5" fill="none" stroke-linecap="round" />
          <circle cx="30" cy="62" r="3.5" fill="#FDF6EC" />
          <circle cx="46" cy="62" r="3.5" fill="#FDF6EC" />
          <circle cx="31" cy="62" r="1.8" fill="#3C2415" />
          <circle cx="47" cy="62" r="1.8" fill="#3C2415" />
          <path d="M32 72 Q38 78 44 72" stroke="#FDF6EC" stroke-width="2.5" stroke-linecap="round" fill="none" />
          <ellipse cx="24" cy="68" rx="4" ry="2.5" fill="#E8A87C" opacity="0.5" />
          <ellipse cx="52" cy="68" rx="4" ry="2.5" fill="#E8A87C" opacity="0.5" />
          <ellipse cx="38" cy="86" rx="30" ry="6" fill="#A0612F" />
        </svg>
      </div>
    </div>
    {% endif %}

  </body>
</html>
